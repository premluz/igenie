import { ArrowRight } from 'lucide-react'
import { usePrestoStore } from '@/store/usePrestoStore'

interface InsightCardProps {
  data: {
    scenarioId: string
    title: string
    description: string
  }
  title: string
  subtitle?: string
}

export function InsightCard({ data, title, subtitle }: InsightCardProps) {
  const { loadScenarioDetail } = usePrestoStore()

  const handleClick = () => {
    loadScenarioDetail(data.scenarioId)
  }

  return (
    <button
      onClick={handleClick}
      className="group relative flex flex-col h-full bg-card border border-border rounded-[4px] overflow-hidden hover:border-accent/50 transition-colors text-left p-4 gap-3"
    >
      <div>
        <h3 className="text-sm font-semibold text-foreground mb-1">{title}</h3>
        {subtitle && (
          <p className="text-xs text-muted-foreground">{subtitle}</p>
        )}
      </div>
      <p className="text-xs text-muted-foreground flex-1 line-clamp-3">{data.title}</p>
      <div className="flex items-center gap-2 text-xs text-accent opacity-0 group-hover:opacity-100 transition-opacity">
        <span>Explore</span>
        <ArrowRight size={12} />
      </div>
    </button>
  )
}
